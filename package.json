{
  "name": "livexec",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"server,worker\" --prefix-colors \"blue,green\" \"npm run server:dev\" \"npm run worker:dev\"",
    "server:dev": "nodemon server.js",
    "worker:dev": "nodemon worker.js",
    "start": "node server.js",
    "worker:start": "node worker.js",
    "verify-endpoints": "node scripts/verify_endpoints.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "bullmq": "^5.71.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
