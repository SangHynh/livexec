{
  "name": "livexec-monorepo",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "server:dev": "npm run dev -w server",
    "worker:dev": "npm run worker:dev -w server",
    "verify-endpoints": "node scripts/verify_endpoints.js",
    "server:start": "npm start -w server",
    "dev": "concurrently --names \"server,worker\" --prefix-colors \"blue,green\" \"npm run server:dev\" \"npm run worker:dev\"",
    "lint": "npm run lint -w server",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0"
  }
}
